---
import { Image } from "astro:assets";
import config from "@/config/config.json";

const { src } = Astro.props;
const {
  logo,
  logo_width,
  logo_height,
  logo_text,
  title,
}: {
  logo: string;
  logo_width: any;
  logo_height: any;
  logo_text: string;
  title: string;
} = config.site;

const width = Number(String(logo_width).replace("px", ""));
const height = Number(String(logo_height).replace("px", ""));
---

<a href="/" class="navbar-brand block w-full max-w-[72vw] sm:max-w-none">
  {
    src || logo ? (
      <Image
        width={width * 2}
        height={height * 2}
        src={src ? src : logo}
        alt={title}
        class="h-auto w-auto max-w-full sm:max-w-none"
        style={{
          width: `${width}px`,
          height: "auto",
        }}
      />
    ) : logo_text ? (
      <span class="block text-sm sm:text-base leading-tight">{logo_text}</span>
    ) : (
      <span class="block text-sm sm:text-base leading-tight">{title}</span>
    )
  }
</a>