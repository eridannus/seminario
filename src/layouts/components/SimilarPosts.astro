---
import dateFormat from "@/lib/utils/dateFormat";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit } from "react-icons/bi";

type Props = {
  posts: CollectionEntry<"posts">[];
};
const { posts } = Astro.props;
---

<div class="row gy-4 justify-center">
  {
    posts.map((post, i: number) => {
      const youtubeMaxThumb = post.data.youtube_id
        ? `https://img.youtube.com/vi/${post.data.youtube_id}/maxresdefault.jpg`
        : null;

      const youtubeHqThumb = post.data.youtube_id
        ? `https://img.youtube.com/vi/${post.data.youtube_id}/hqdefault.jpg`
        : null;

      const targetUrl = post.data.youtube_url || `/${post.id}`;

      return (
        <div class={`col-12 sm:col-6 md:col-4 ${i === 2 && "hidden md:block"}`}>
          {(post.data.image || youtubeMaxThumb) && (
            <a
              href={targetUrl}
              target={post.data.youtube_url ? "_blank" : undefined}
              rel={post.data.youtube_url ? "noopener noreferrer" : undefined}
              class="rounded-lg block hover:text-primary overflow-hidden group"
            >
              <div class="aspect-video w-full overflow-hidden rounded-lg">
                {post.data.image ? (
                  <Image
                    class="group-hover:scale-[1.05] transition duration-300 w-full h-full object-cover object-center"
                    src={post.data.image}
                    alt={post.data.title}
                    width={445}
                    height={230}
                  />
                ) : (
                  <img
                    class="group-hover:scale-[1.05] scale-[1.02] transition duration-300 w-full h-full object-cover object-center"
                    src={youtubeMaxThumb!}
                    alt={post.data.title}
                    loading="lazy"
                    onerror={`this.onerror=null;this.src='${youtubeHqThumb}';`}
                  />
                )}
              </div>
            </a>
          )}
          <ul class="mt-4 text-text flex flex-wrap items-center text-sm">
            <li class="mb-2 mr-4 flex items-center flex-wrap font-medium">
              <BiCalendarEdit className="mr-1 h-[16px] w-[16px] text-gray-600" />
              {dateFormat(post.data.date!)}
            </li>
          </ul>
          <h3 class="h5">
            <a
              href={targetUrl}
              target={post.data.youtube_url ? "_blank" : undefined}
              rel={post.data.youtube_url ? "noopener noreferrer" : undefined}
              class="block hover:text-primary transition duration-300"
            >
              {post.data.title}
            </a>
          </h3>
        </div>
      );
    })
  }
</div>