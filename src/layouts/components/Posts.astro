---
import dateFormat from "@/lib/utils/dateFormat";
import { plainify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit } from "react-icons/bi";

type Props = {
  posts: CollectionEntry<"posts">[];
  className?: string;
  fluid?: boolean;
};

const { className, posts, fluid } = Astro.props;
---

<div
  class={`row gy-5 gx-4 ${className} ${posts.length == 1 ? "justify-center" : ""} `}
>
  {
    posts.map((post, i: number) => {
      const youtubeMaxThumb = post.data.youtube_id
        ? `https://img.youtube.com/vi/${post.data.youtube_id}/maxresdefault.jpg`
        : null;

      const youtubeHqThumb = post.data.youtube_id
        ? `https://img.youtube.com/vi/${post.data.youtube_id}/hqdefault.jpg`
        : null;

      const targetUrl = post.data.youtube_url || `/blog/${post.id}`;

      return (
        <div class={i === 0 && fluid != false ? "col-12" : "col-12 sm:col-6"}>
          {(post.data.image || youtubeMaxThumb) && (
            <a
              href={targetUrl}
              target={post.data.youtube_url ? "_blank" : undefined}
              rel={post.data.youtube_url ? "noopener noreferrer" : undefined}
              class="rounded-lg block hover:text-primary overflow-hidden group"
            >
              <div class="aspect-video w-full overflow-hidden rounded-lg">
                {post.data.image ? (
                  <Image
                    class="group-hover:scale-[1.03] transition duration-300 w-full h-full object-cover object-center"
                    src={post.data.image}
                    alt={post.data.title}
                    width={i === 0 ? 925 : 445}
                    height={i === 0 ? 475 : 230}
                  />
                ) : (
                  <img
                    class="group-hover:scale-[1.03] transition duration-300 w-full h-full object-cover object-center"
                    src={youtubeMaxThumb!}
                    alt={post.data.title}
                    loading="lazy"
                    onerror={`this.onerror=null;this.src='${youtubeHqThumb}';`}
                  />
                )}
              </div>
            </a>
          )}
          <ul class="mt-6 mb-4 flex flex-wrap items-center text-text">
            <li class="mr-5 flex items-center flex-wrap font-medium">
              <BiCalendarEdit className="mr-1 h-5 w-5 text-gray-600" />
              {dateFormat(post.data.date!)}
            </li>
          </ul>
          <h3 class="mb-4">
            <a
              href={targetUrl}
              target={post.data.youtube_url ? "_blank" : undefined}
              rel={post.data.youtube_url ? "noopener noreferrer" : undefined}
              class="block hover:text-primary transition duration-300"
            >
              {post.data.title}
            </a>
          </h3>
          <p class="text-text line-clamp-2">{plainify(post.body ?? "")}</p>
        </div>
      );
    })
  }
</div>