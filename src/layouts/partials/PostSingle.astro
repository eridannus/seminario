---
import Share from "@/components/Share.astro";
import SimilarPosts from "@/components/SimilarPosts.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import similerItems from "@/lib/utils/similarItems";
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import { render } from "astro:content";
import { BiCalendarEdit, BiLinkExternal } from "react-icons/bi";

const posts = await getSinglePage("posts");
const { post } = Astro.props;
const similarPosts = similerItems(post, posts, post.slug);
const { Content } = await render(post);
const {
  title,
  description,
  image,
  date,
  tags,
  youtube_id,
  youtube_url,
  event_url,
  speaker,
  location,
} = post.data;

const youtubeMaxThumb = youtube_id
  ? `https://img.youtube.com/vi/${youtube_id}/maxresdefault.jpg`
  : null;

const youtubeHqThumb = youtube_id
  ? `https://img.youtube.com/vi/${youtube_id}/hqdefault.jpg`
  : null;

const primaryUrl = event_url || youtube_url || null;
const primaryLabel = event_url ? "Acceder al evento" : youtube_url ? "Ver en YouTube" : null;
---

<section class="section">
  <div class="container">
    <article class="row justify-center">
      <div class="md:col-10 text-center">
        <h1 set:html={markdownify(title)} class="h2" />
        <ul class="mt-4 flex flex-wrap items-center justify-center text-text">
          <li class="mx-3 flex items-center flex-wrap font-medium">
            <BiCalendarEdit className="mr-1 h-5 w-5 text-gray-600" />
            {dateFormat(date)}
          </li>
        </ul>

        {speaker && <p class="mt-4 text-lg text-text">{speaker}</p>}
        {location && <p class="mt-2 text-text">{location}</p>}

        {
          primaryUrl && primaryLabel && (
            <div class="mt-6">
              <a
                href={primaryUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center rounded-lg bg-primary px-5 py-3 font-semibold text-white hover:opacity-90 transition duration-300"
              >
                <BiLinkExternal className="mr-2 h-5 w-5" />
                {primaryLabel}
              </a>
            </div>
          )
        }
      </div>

      <div class="col-12 mt-8 mb-2">
        {
          image ? (
            <Image
              src={image}
              height={500}
              width={1000}
              alt={title}
              class="rounded-lg w-full object-cover"
            />
          ) : youtubeMaxThumb ? (
            <div class="aspect-video w-full overflow-hidden rounded-lg">
              <img
                src={youtubeMaxThumb}
                alt={title}
                class="rounded-lg w-full h-full object-cover object-center scale-[1.02]"
                loading="lazy"
                onerror={`this.onerror=null;this.src='${youtubeHqThumb}';`}
              />
            </div>
          ) : null
        }
      </div>

      <div class="md:col-10">
        <div class="content mb-16 text-left">
          <Content />
        </div>
        {
          tags.length > 0 && (
            <div class="flex flex-wrap items-center justify-between">
              <ul class="mr-4 mb-4 space-x-3">
                {
                  tags.map((tag: string) => (
                    <li class="inline-block">
                      <span class="block rounded-lg bg-light px-4 py-2 font-semibold text-dark text-sm">
                        #{tag}
                      </span>
                    </li>
                  ))
                }
              </ul>
              <Share
                className="social-share mb-4"
                title={title}
                description={description}
                slug={post.id}
              />
            </div>
          )
        }
      </div>
    </article>
  </div>
</section>

{
  similarPosts.length > 0 && (
    <section class="section pt-0">
      <div class="container">
        <h2 class="mb-8 text-center h3">Sesiones relacionadas</h2>
        <SimilarPosts posts={similarPosts.slice(0, 3)} />
      </div>
    </section>
  )
}